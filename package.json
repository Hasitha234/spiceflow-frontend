    "dayjs": "^1.11.21",
    "framer-motion": "^12.42.2",
    "html5-qrcode": "^2.3.8",
    "i18next": "^26.3.4",
    "jspdf": "^4.2.1",
    "jspdf-autotable": "^5.0.8",
    "jwt-decode": "^4.0.0",
    "qrcode.react": "^4.2.0",
    "react": "^19.2.6",
    "react-dom": "^19.2.6",
    "react-hook-form": "^7.80.0",
    "react-i18next": "^17.0.8",
